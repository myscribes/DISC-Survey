# AWS SES configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Verified sender address in Amazon SES (must be verified in your AWS account)
SES_FROM_EMAIL=surveys@discconnector.com

# Admin inbox that receives every submission
SURVEY_ADMIN_EMAIL=surveys@discconnector.com

# Survey settings
SURVEY_ID=Session 1
ADMIN_PASSWORD=adminpassword
